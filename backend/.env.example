# Copy to .env and adjust as needed. All vars are prefixed with CINEREC_.
CINEREC_DATABASE_URL=postgresql+psycopg://cinerec:cinerec@localhost:5432/cinerec

# Embedding backend: "sentence-transformers" (semantic) or "hash" (offline, fast)
CINEREC_EMBEDDER=sentence-transformers
CINEREC_EMBEDDING_MODEL=all-MiniLM-L6-v2
CINEREC_EMBEDDING_DIM=384

# Optional TMDB enrichment (not required for the MovieLens demo)
# CINEREC_TMDB_API_KEY=your_key_here
